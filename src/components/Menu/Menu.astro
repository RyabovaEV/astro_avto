---
import styles from './Menu.module.scss'

interface Props {
  class?: string;
  mobile?: boolean;
}

const { class: className, mobile = false } = Astro.props;
const currentPath = Astro.url.pathname

type MenuItem = {
  href: string
  title: string
  ariaLabel?: string
  children?: MenuItem[]
}

const menuItems: MenuItem[] = [
  {
    href: '/',
    title: 'Главная',
  },
  {
    href: '/schedule',
    title: 'Расписание',
    ariaLabel: 'Подменю Расписание',
    children: [
      {href: '/schedule/city', title: 'Городские'},
      {href: '/schedule/suburban', title: 'Пригородные'},
    ],
  },
  {
    href: '/driving-school',
    title: 'Автошкола',
    ariaLabel: 'Подменю Автошкола',
    children: [
      {href: '/driving-school/info', title: 'Информация'},
      {href: '/driving-school/training-plan', title: 'План обучения'},
      {href: '/driving-school/documents', title: 'Документы'},
    ],
  },
  {
    href: '/about',
    title: 'О предприятии',
    ariaLabel: 'Подменю Автошкола',
    children: [
      {href: '/about/history', title: 'История'},
      {href: '/about/vacancies', title: 'Вакансии'},
      {href: '/about/documents', title: 'Документы'},
      {href: '/about/contacts', title: 'Контакты'},
    ],
  },
]
---

<nav
  class={[styles.menu, className].filter(Boolean).join(' ')}
  aria-label="Главное меню"
  {...(mobile ? { 'data-menu-mobile': '' } : {})}
>
  <ul
    class={styles.menu__list}
    role="menubar"
  >
    {menuItems.map(({href, title, ariaLabel,children}) => {
      const isSectionActive = currentPath === href || currentPath.startsWith(href + '/')
      const isRootActive = currentPath === href

      return (
        <li
          key={href}
          class={`
            ${styles.menu__item}
            ${children?.length ? styles.menu__dropdown : ''}
            ${isRootActive ? styles.active : ''}
          `}
          role="none"
          {...(children?.length ? { 'data-has-submenu': '' } : {})}
          {...(children?.length && isSectionActive ? { 'data-accordion-open': '' } : {})}
        >
          <a
            href={href}
            class={styles.menu__link}
            role="menuitem"
            aria-haspopup="true"
            aria-expanded={isSectionActive ? "true" : "false"}
          >{title}</a>

          {children?.length && (
            <ul
              class={styles.menu__submenu}
              role="menu"
              aria-label={ariaLabel}
            >
              {children.map(({href: subHref, title: subTitle}) => {
                const isSubActive = currentPath === subHref
                return (
                  <li
                    key={subHref}
                    class={`
                      ${styles.menu__submenu__item}
                      ${isSubActive ? styles.active : ''}
                    `}
                  >
                    <a
                      href={subHref}
                      class={styles.menu__submenu__link}
                      role="menuitem"
                    >{subTitle}</a>
                  </li>
                )
              })}
            </ul>
          )}
        </li>
      )
    })}
  </ul>
</nav>
