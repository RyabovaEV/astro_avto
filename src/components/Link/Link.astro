---
interface Props {
  href?: string;
  label?: string;
  className?: string;
  ariaLabel?: string;
  title?: string;
  isButton?: boolean;
  style?: 'link' | 'button';
  type?: 'button' | 'submit' | 'reset';
}

const {
  href,
  label = 'Oзнакомиться с изменениями можно по ссылке',
  className = '',
  ariaLabel,
  title,
  style = 'link',
  isButton = false,
  type = 'button',
} = Astro.props;

import styles from './Link.module.scss'
---

{href && !isButton ? (
  <a
    href={href}
    class= {`${style === 'link' ? styles.link : styles.button} 
            ${className ? className : ''}`}
    aria-label={ariaLabel}
    title={title}
  >
    <slot>{label}</slot>
  </a>
) : (
  <button
    class={`${styles.button} ${className ? className : ''}`}
    aria-label={ariaLabel}
    title={title}
    type={type}
  >
    <slot>{label}</slot>
  </button>
)}
