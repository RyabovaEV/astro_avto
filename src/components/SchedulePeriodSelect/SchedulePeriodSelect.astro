---
import styles from './SchedulePeriodSelect.module.scss';

interface Props {
  switchAtLabel: string;
}

const { switchAtLabel } = Astro.props;
---

<div class={styles.control} data-schedule-period-control>
  <p class={styles.label}>Период расписания</p>
  <div class={styles.toggle}>
    <button
      class={styles.button}
      data-schedule-period-btn="old"
      data-active="true"
      type="button"
    >
      Текущее
    </button>
    <button
      class={styles.button}
      data-schedule-period-btn="current"
      type="button"
    >
      Новое (с {switchAtLabel})
    </button>
  </div>
</div>
