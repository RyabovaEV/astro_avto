---
import Layout from '../layouts/Layout/Layout.astro';
import Section from "../components/Section/Section.astro";
import News from "../components/News/News.astro";
import Docs from "../components/Docs/Docs.astro";
import {newsList} from '../data/news';
import {linksIndex} from "../data/links";
import Insurance from "../components/Insurance/Insurance.astro";
---

<Layout>
  <Section
    title=`ООО&nbsp;“Авто”, ООО&nbsp;“Киришиавто”`
    subtitle="Oфициальный сайт"
    ariaName="title-block"
    isInfo
    isH1
  ></Section>
  <Section
    title="Страхование"
    ariaName="enchurias-block"
    isInfo
  >
    <Insurance />
  </Section>
  <Section
    title="Новости"
    ariaName="news-block"
    isInfo
    buttonLabel="Все нововсти"
  >
    <News newsList={newsList} />
  </Section>
  <Section
    title="Документы"
    ariaName="document-block"
    isInfo
  >
    <Docs links={linksIndex} />
  </Section>

</Layout>
