---
import SectionLayout from '../../../layouts/SectionLayout/SectionLayout.astro';
import { getSidebarItems } from '../../../data/pathMenu';
import Section from "../../../components/Section/Section.astro";
import Accordion from "../../../components/Accordion/Accordion.astro";
import AccordionItem from "../../../components/Accordion/AccordionItem.astro";
import TrainingPlanTable from "../../../components/TrainingPlanTable/TrainingPlanTable.astro";
import { programsMap } from "../../../data/driving-school";

const sidebarItems = getSidebarItems('/driving-school');

const defaultOpenIndex = 0;
const sections = [
  { title: 'Учебный план профессиональной подготовки водителей транспортных средств категории “В”', program: programsMap.B },
  { title: 'Учебный план профессиональной переподготовки водителей транспортных средств с категории “В” на категорию “D”', program: programsMap.BD },
  { title: 'Учебный план профессиональной переподготовки водителей транспортных средств с категории “С” на категорию “D”', program: programsMap.CD },
  { title: 'Учебный план профессиональной переподготовки водителей транспортных средств с категории “В” на категорию “С”', program: programsMap.BC },
];
---

<SectionLayout title="Автошкола" sidebarItems={sidebarItems}>
  <Section
    title=`План обучения`
    subtitle="Автошкола"
    ariaName="title-block"
    isInfo
    isH1
  />
  <Accordion aria-label="Разделы" >
    {sections.map((section, i) => (
      <AccordionItem title={section.title} initiallyOpen={i === defaultOpenIndex}>
        <TrainingPlanTable program={section.program} />
      </AccordionItem>
    ))}
  </Accordion>
</SectionLayout>
