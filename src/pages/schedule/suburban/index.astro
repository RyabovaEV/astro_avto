---
import SectionLayout from '../../../layouts/SectionLayout/SectionLayout.astro';
import ScheduleTable
  from '../../../components/ScheduleTable/ScheduleTable.astro';
import type {RouteSchedule} from '../../../data/schedule';
import {suburbanRoutes, suburbanComments} from '../../../data/schedule';
import {getSidebarItems} from '../../../data/pathMenu';
import Section from "../../../components/Section/Section.astro";
import ScheduleComment
  from "../../../components/ScheduleComment/ScheduleComment.astro";
import Message from "../../../components/Message/Message.astro";
import SchedulePeriodSelect
  from "../../../components/SchedulePeriodSelect/SchedulePeriodSelect.astro";
import SchedulePeriodRoot
  from "../../../components/SchedulePeriodRoot/SchedulePeriodRoot.astro";

const sidebarItems = getSidebarItems('/schedule');
const switchAt = '2026-05-01T00:00:00+03:00';
const switchAtLabel = '01.05.2026';
const nextModulePath = '../../../data/schedule/nextSchedule/suburban_next.ts';
const nextModules = import.meta.glob('../../../data/schedule/nextSchedule/suburban_next.ts');

let suburbanNextRoutes: RouteSchedule[] = [];

if (nextModulePath in nextModules) {
  const moduleLoader = nextModules[nextModulePath];
  const module = await moduleLoader();
  const maybeNextRoutes = (module as {
    suburbanNew?: RouteSchedule[]
  }).suburbanNew;

  if (Array.isArray(maybeNextRoutes)) {
    suburbanNextRoutes = maybeNextRoutes;
  }
}

const hasSuburbanNext = suburbanNextRoutes.length > 0;
---

<SectionLayout
  title="Расписание"
  sidebarItems={sidebarItems}
>
  <SchedulePeriodRoot
    title="Пригородные маршруты"
    switchAt={switchAt}
    switchAtLabel={switchAtLabel}
    currentRoutes={suburbanRoutes}
    currentComments={suburbanComments}
    nextRoutes={suburbanNextRoutes}
  />
  <Message
    message="В процессе перевозок возможны изменения и дополнения в расписании о чем будет дополнительно информировано."
    type="information"
  />
</SectionLayout>
