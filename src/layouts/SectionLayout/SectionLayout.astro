---
import Layout from '../Layout/Layout.astro';
import Sidebar from '../../components/Sidebar/Sidebar.astro';
import SidebarNav from '../../components/Sidebar/SidebarNav.astro';
import type { SidebarItem } from '../../components/Sidebar/Sidebar.astro';

interface Props {
  title: string;
  sidebarItems: SidebarItem[];
  pageTitle?: string;
  description?: string;
}

const { title, sidebarItems, pageTitle, description } = Astro.props;

import styles from './SectionLayout.module.scss';
---

<Layout  title={pageTitle} description={description}>
  <div class={styles.wrapper}>
    <div class={styles.sidebarDesktop}>
      <Sidebar title={title} items={sidebarItems} />
    </div>

    <div class={styles.tabsScroll}>
      <SidebarNav items={sidebarItems} layout="tabs" />
    </div>

    <div class={styles.content}>
      <slot />
    </div>
  </div>
</Layout>
